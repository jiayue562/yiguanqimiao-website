, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">刀有鞘</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">4</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">护肺少食辛辣</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">金的根</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">5</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">找水行朋友学柔</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">金生水</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">6</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">把"不行"改成"这样更好"</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">态度分离</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">7</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">写"我的标准护了谁"</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">边界意义</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">8</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">对火行伴侣陪而不讲理</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">行动爱</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">9</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">读《原则》一章</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">规则系统</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">10</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">给木行朋友先肯定再修</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">金克木化解</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">11</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">列"我苛求的三件事"</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">适度放宽</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">12</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">每周一次主动暖话</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">不冷硬</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">13</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">找一个土行朋友学承载</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">土生金</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">14</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">写下"我的锋利下面有暖"</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">自我定义</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">15</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">运动后记录松紧</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">收放</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">16</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">对伙伴说"我在"</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">确定性</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">17</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">复盘：本周锋利几次、暖几次</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">平衡</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">18</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">写"我是刀，也有鞘"</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">自我接纳</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">19</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">在评论区留"我的金要什么"</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">社群镜像</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">20</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">重读本文，划掉"我冷漠"</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">自我原谅</span></section></td></tr><tr><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">21</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">庆祝：我是一把有鞘的剑</span></section></td><td style="border: 1px solid rgb(217, 223, 228);padding: 9px 12px;font-size: 0.75em;line-height: 22px;vertical-align: top;"><section><span leaf="">接纳金</span></section></td></tr></tbody></table><h2 style="padding: 1px 12.5px;color: rgb(255, 255, 255);margin: 1.2em 0px 1em;border-radius: 4px;display: inline-block;background-color: rgb(72, 112, 172);font-size: 1.3em;"><span leaf="">二十五、番外·金行人的组织角色深案例</span></h2><p style="margin: 1em 0px;"><span leaf="">一家律所合伙人分裂：三位金行合伙人，标准极高，互相挑刺，会议变成"谁更对"的擂台，客户方案卡在内耗里。我让他们做五行翻译：你们不是"谁对谁错"，是"三把刀互砍"。解法：设"金行轮值裁判"制，每次只一人 final say，其余提意见不否决；同时引入一位火行做"客户关系官"，把冷标准翻译成暖沟通。</span></p><p style="margin: 1em 0px;"><span leaf="">三月后，内耗降了，客户续约升了。一位合伙人说："原来我的锋利没错，错在三把刀同时出鞘。" 金行组织的智慧：标准要锋利，但出鞘要有序。</span></p><hr style="margin-top: 20px;margin-bottom: 20px;border-width: 2px 0px 0px;border-style: solid none none;border-color: rgb(238, 242, 245) currentcolor currentcolor;border-image: none;border-radius: 2px;"  /><h2 style="padding: 1px 12.5px;color: rgb(255, 255, 255);margin: 1.2em 0px 1em;border-radius: 4px;display: inline-block;background-color: rgb(72, 112, 172);font-size: 1.3em;"><span leaf="">二十六、番外·金行人进阶三问</span></h2><p style="margin: 1em 0px;"><strong style="color: rgb(72, 112, 172);"><span leaf="">问：金行人适合创业吗？</span></strong><span leaf="">&nbsp;适合做"把关型"创业（风控、合规、精密制造），不适合纯拓荒。金行创业要配木行做开创，自己守住"成器"的底线。</span></p><p style="margin: 1em 0px;"><strong style="color: rgb(72, 112, 172);"><span leaf="">问：金行孩子被说"小大人"怎么办？</span></strong><span leaf="">&nbsp;别怕。金孩子的"较真"是天赋，引导到"守规则、讲公平"的正面，而非打压成"听话"。给他"为什么"而非"因为我说了算"。</span></p><p style="margin: 1em 0px;"><strong style="color: rgb(72, 112, 172);"><span leaf="">问：金行伴侣的冷，是真的不爱吗？</span></strong><span leaf="">&nbsp;几乎从来不是。金的冷是边界，不是心冷。你越用情绪逼他，他越缩；你用行动陪他，他越暖。爱的语言，对金是"我在"。</span></p><h2 style="padding: 1px 12.5px;color: rgb(255, 255, 255);margin: 1.2em 0px 1em;border-radius: 4px;display: inline-block;background-color: rgb(72, 112, 172);font-size: 1.3em;"><span leaf="">二十七、金篇心法三则</span></h2><ul style="padding-left: 1rem;margin-left: 1rem;font-size: 0.9rem;list-style-type: disc;" class="list-paddingleft-1"><li><section><span leaf="">你的锋利，是世界稀缺的清醒，别因被说冷就磨平。</span></section></li><li><section><span leaf="">刀要有鞘：把标准说出口时，包一层温度。</span></section></li><li><section><span leaf="">示弱不是钝，是锐者的勇气——偶尔说"我累了"。</span></section></li></ul><p style="margin: 1em 0px;"><span leaf="">下一篇，我们讲水——那群最被低估、也最深的行者。</span></p><h2 style="padding: 1px 12.5px;color: rgb(255, 255, 255);margin: 1.2em 0px 1em;border-radius: 4px;display: inline-block;background-color: rgb(72, 112, 172);font-size: 1.3em;"><span leaf="">二十八、金篇收官</span></h2><p style="margin: 1em 0px;"><span leaf="">金行人，最后送你一句：你不必变成温吞的棉，你可以是包了鞘的剑——锋利依旧，却不再伤人。下一篇，我们讲水——那群最被低估、也最深的行者。</span></p><h2 style="padding: 1px 12.5px;color: rgb(255, 255, 255);margin: 1.2em 0px 1em;border-radius: 4px;display: inline-block;background-color: rgb(72, 112, 172);font-size: 1.3em;"><span leaf="">二十九、金篇金句三则</span></h2><ul style="padding-left: 1rem;margin-left: 1rem;font-size: 0.9rem;list-style-type: disc;" class="list-paddingleft-1"><li><section><span leaf="">金不是冷漠，是还没被教会怎么暖。</span></section></li><li><section><span leaf="">刀要有鞘，锋利也要有温度。</span></section></li><li><section><span leaf="">你的标准，是清醒；你的态度，是选择。</span></section></li></ul><h2 style="padding: 1px 12.5px;color: rgb(255, 255, 255);margin: 1.2em 0px 1em;border-radius: 4px;display: inline-block;background-color: rgb(72, 112, 172);font-size: 1.3em;"><span leaf="">三十、写在金篇最后</span></h2><p style="margin: 1em 0px;"><span leaf="">金行人，这世界需要你的清醒，也需要你的温度。愿你做一把有鞘的剑——锋利依旧，却不再伤人；标准依旧，却多了份懂得。你的边界，是你对自己的尊重；你的温度，是你对他人的慈悲。两者从不是敌人。当你学会把锋利包进温度，你会发现，原来你一直想要的，不是被怕，是被信。而被信的刀，比被怕的刀，走得更远。</span></p><p style="margin: 1em 0px;" data-pm-slice="0 0 []"><strong style="color: rgb(72, 112, 172);"><span leaf="">作者：悟空（贾悦）· 以观其妙书院</span></strong></p><section data-pm-slice="0 0 []"><span style="font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size: 14px;font-style: normal;font-variant-ligatures: normal;font-variant-caps: normal;font-weight: 400;letter-spacing: normal;orphans: 2;text-align: start;text-indent: 0px;text-transform: none;widows: 2;word-spacing: 0px;-webkit-text-stroke-width: 0px;text-decoration-thickness: initial;text-decoration-style: initial;text-decoration-color: initial;display: inline !important;float: none;" data-pm-slice="0 0 []"><span leaf=""><span textstyle="" style="color: rgb(255, 0, 0);font-weight: bold;">"我正在找一个合伙人——不需要懂AI技术，不需要懂五行人格心理学，不需要你懂企业文化。只需要你认识足够多的企业老板，你替我开口说一句'我认识一个人很厉害'，剩下的我来交付。利润你定。"</span></span></span></section><p style="margin: 1em 0px;"><span leaf=""><br  /></span></p><p style="margin: 1em 0px;"><em style="padding: 0px 3px 0px 0px;"><span leaf=""><br  /></span></em></p></section><p style="display: none;"><mp-style-type data-value="10000"></mp-style-type></p>
