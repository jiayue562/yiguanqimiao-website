def assess_yin_yang(user_state: Dict) -&gt; Dict:
    """
    评估阴阳状态
    
    Args:
        user_state: 用户当前状态描述
    
    Returns:
        {
            "state": str,       # 阴阳状态
            "level": str,       # 程度（轻度/中度/重度）
            "recommendation": str,  # 调整建议
