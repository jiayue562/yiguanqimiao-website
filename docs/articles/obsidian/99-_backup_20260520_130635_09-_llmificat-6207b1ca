<h2>🎯 编译请求模板</h2>
<h3>批量编译请求</h3>
<pre><code>batch_compile_request:
  knowledge_base: "知识库名称"
  scope: "corporate"
  sources:
    - "raw/手册/*.pdf"
    - "raw/文档/*.docx"
    - "raw/网页/*.html"
  compilation_params:
    llm_model: "gpt-4"
    temperature: 0.3
    max_tokens: 4000
  schema_definition: "schema/config.yaml"
  output_path: "wiki/"
  notification:
    on_success: "email/webhook"
    on_failure: "email/webhook"</code></pre>
<h3>增量更新请求</h3>
<pre><code>incremental_update_request:
  knowledge_base: "知识库名称"
  action: "merge"
  sources:
    - "raw/新文档.pdf"
  target_topic: "主题关键词"
  update_strategy: "append/merge/replace"
  validation_required: true</code></pre>
