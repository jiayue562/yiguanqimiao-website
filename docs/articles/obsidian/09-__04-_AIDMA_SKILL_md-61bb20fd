<thead><tr>
<th>策略类型</th>
<th>做法</th>
<th>示例</th>
</tr></thead><tbody>
<tr>
<td><strong>尺寸放大</strong></td>
<td>增大视觉元素</td>
<td>大标题、大图片</td>
</tr>
<tr>
<td><strong>色彩对比</strong></td>
<td>使用高对比色</td>
<td>黑底黄字</td>
</tr>
<tr>
<td><strong>动态吸引</strong></td>
<td>动画、视频、动效</td>
<td>视频广告</td>
</tr>
<tr>
<td><strong>悬念设计</strong></td>
<td>制造好奇</td>
<td>悬念文案</td>
</tr>
<tr>
<td><strong>名人效应</strong></td>
<td>KOL、明星代言</td>
<td>明星海报</td>
</tr>
</tbody></table>
