def classify_by_extension(file_path):
    """
    基于扩展名分类
    """
    extensions = {
        '.md': 'markdown',
        '.py': 'python',
        '.js': 'javascript',
        '.json': 'data',
        '.yaml': 'config',
        '.ps1': 'powershell'
    }
    return extensions.get(file_path.suffix.lower(), 'other')
