├── framework/               # Framework层
│   └── qiye-wenhua-framework.yaml
├── workflow/                # 工作流层
│   ├── 7step-workflow.md
│   ├── diagnose-workflow.md
│   └── iterate-workflow.md
└── sop/                     # SOP层
    ├── diagnose-sop.md
    ├── design-sop.md
    └── implement-sop.md
```</p>
