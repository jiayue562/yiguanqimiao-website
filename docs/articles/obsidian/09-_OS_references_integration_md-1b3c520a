<h3>3.2 调用接口</h3>
<pre><code>// 五行人格分析接口
interface WuXingAnalysisRequest {
  // 分析对象
  target: {
    type: "个人" | "团队" | "组织";
    id: string;
    name: string;
  };
  
  // 分析深度
  depth: "快速" | "标准" | "深度";
  
  // 分析维度
  dimensions: {
    yiXin?: boolean;      // 一心
    sanJie?: boolean;     // 三界
    wuXing?: boolean;     // 五行
