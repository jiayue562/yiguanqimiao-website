    zhuanHua?: boolean;   // 转化
  };
  
  // 输入数据
  data: {
    questionnaire?: any;   // 问卷数据
    interview?: string;    // 访谈记录
    observation?: string;  // 观察记录
  };
}

interface WuXingAnalysisResponse {
  // 五行判定
  wuXingType: {
    primary: "木" | "火" | "土" | "金" | "水";
    secondary?: string;
    confidence: number;
  };
  
  // 一心状态
  yiXin: {
    state: "阳" | "阴" | "平衡";
    description: string;
  };
  
  // 三界分析
  sanJie: {
    shen: { state: string; indicators: string[] };
    xin: { state: string; indicators: string[] };
    ling: { state: string; indicators: string[] };
  };
  
  // 九层定位
  jiuCeng: {
    level: number;  // 1-9
    description: string;
    characteristics: string[];
  };
  
  // 转化建议
  zhuanHua: {
    baYinQuYang: string[];  // 拔阴取阳建议
    huaKeWeiSheng: string[]; // 化克为生路径
    xingWeiSheJi: any;       // B=MAP行为设计
  };
}</code></pre>
