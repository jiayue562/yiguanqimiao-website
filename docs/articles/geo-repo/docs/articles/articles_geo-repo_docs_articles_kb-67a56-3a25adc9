<p>│   ├── papers/            # 论文</p>

<p>│   ├── code/              # 代码</p>

<p>│   ├── datasets/          # 数据集</p>

<p>│   └── images/            # 图片</p>

<p>├── wiki/                   # PROCESSING加工区</p>

<p>│   ├── summaries/         # 摘要</p>

<p>│   ├── entities/          # 实体页</p>

<p>│   ├── concepts/          # 概念页</p>

<p>│   └── comparisons/       # 对比页</p>

<p>└── config/                 # 配置区</p>

<p>├── AGENTS.md          # Agent操作手册</p>

<p>└── CLAUDE.md          # Claude Code配置</p>

</code></pre>

